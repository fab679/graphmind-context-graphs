# ══════════════════════════════════════════════════════════════════════════════
# Graphmind Context Graphs — Environment Variables
# Copy to .env and fill in your values.
# ══════════════════════════════════════════════════════════════════════════════

# ── Graphmind Database ─────────────────────────────────────────────────────────
GRAPHMIND_URL=http://localhost:8080
GRAPHMIND_TOKEN=
GRAPHMIND_USERNAME=
GRAPHMIND_PASSWORD=

# ── LLM / Agent Model ────────────────────────────────────────────────────────
# Format: "provider:model" (LangChain initChatModel)
MODEL=openai:gpt-4.1-mini
OBSERVER_MODEL=

# ── Embedding Provider (TypeScript SDK) ───────────────────────────────────────
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Provider API Keys ─────────────────────────────────────────────────────────
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
