# Graphmind Database
GRAPHMIND_URL=http://localhost:8080
GRAPHMIND_TOKEN=
# Username/password auth (alternative to token — token takes precedence if both set)
GRAPHMIND_USERNAME=
GRAPHMIND_PASSWORD=

# ── LLM / Agent Model ────────────────────────────────────────────────────────
# Uses LangChain's initChatModel format: "provider:model"
# Examples:
#   MODEL=openai:gpt-4.1-mini
#   MODEL=anthropic:claude-sonnet-4-6
#   MODEL=google-genai:gemini-2.5-flash
MODEL=openai:gpt-4.1-mini

# Observer model for ablation filtering (defaults to MODEL if not set)
OBSERVER_MODEL=

# ── Embedding Provider ────────────────────────────────────────────────────────
# Provider name must match an installed @langchain/* package
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Provider API Keys (set the one matching your provider) ────────────────────
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# COHERE_API_KEY=
