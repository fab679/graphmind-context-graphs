# ── Graphmind Database ─────────────────────────────────────────────────────────
GRAPHMIND_URL=http://localhost:8080
GRAPHMIND_TOKEN=
GRAPHMIND_USERNAME=
GRAPHMIND_PASSWORD=

# ── LLM / Agent Model ────────────────────────────────────────────────────────
# Uses LangChain's init_chat_model format: "provider:model"
MODEL=openai:gpt-4.1-mini
OBSERVER_MODEL=

# ── Provider API Keys ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
