{
  "name": "graphmind-context-graphs",
  "version": "0.1.0",
  "description": "Context Graph middleware for LangChain AI agents - captures decision traces and reasoning patterns",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:examples": "vitest run --project examples",
    "example": "tsx examples/run-agent.ts",
    "example:multi-domain": "tsx examples/multi-domain-agents.ts",
    "example:skills": "tsx examples/skills-demo.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "langchain",
    "context-graph",
    "ai-agents",
    "decision-traces",
    "middleware",
    "graphmind",
    "graph-database"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@langchain/core": ">=1.0.0",
    "@langchain/langgraph": ">=1.0.0",
    "langchain": ">=1.0.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "graphmind-sdk": "^0.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@langchain/core": "^1.1.36",
    "@langchain/langgraph": "^1.2.6",
    "@langchain/openai": "^1.3.1",
    "@types/node": "^25.5.0",
    "langchain": "^1.2.37",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
