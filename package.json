{
  "name": "graphmind-context-graphs",
  "version": "0.3.0",
  "description": "Director's Commentary middleware for AI agents - captures decision traces, builds dynamic brain maps, and evolves institutional wisdom",
  "repository": {
    "type": "git",
    "url": "https://github.com/fab679/graphmind-context-graphs.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:examples": "vitest run --project examples",
    "example": "tsx examples/basic-context-graph.ts",
    "example:coding": "tsx examples/coding-agent.ts",
    "example:multi-agent": "tsx examples/multi-agent-shared.ts",
    "example:runtime": "tsx examples/runtime-context.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "langchain",
    "context-graph",
    "ai-agents",
    "decision-traces",
    "middleware",
    "graphmind",
    "graph-database",
    "brain-mapping",
    "schema-awareness",
    "multi-agent",
    "knowledge-lifecycle"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@langchain/core": ">=1.0.0",
    "@langchain/langgraph": ">=1.0.0",
    "langchain": ">=1.0.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "graphmind-sdk": "^0.8.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@langchain/core": "^1.1.36",
    "@langchain/langgraph": "^1.2.6",
    "@langchain/openai": "^1.3.1",
    "@types/node": "^25.5.0",
    "langchain": "^1.2.37",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
